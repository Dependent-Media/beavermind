    "description": "AI-powered design automation for Beaver Builder.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "anthropic-ai/sdk": "^0.7",
        "nyholm/psr7": "^1.8",
        "symfony/http-client": "^6.4 || ^7.0"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
